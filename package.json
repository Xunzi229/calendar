{
  "name": "calendar",
  "version": "0.1.0",
  "description": "A desktop Chinese calendar app.",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "package": "npm run build && electron-builder --win nsis portable",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "build": {
    "appId": "com.local.calendar",
    "productName": "Calendar",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
